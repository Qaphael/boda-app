# ==========================================
# SafeBoda Gulu Backend Configuration Template
# Configure these values on your VPS instance.
# ==========================================

# Main application port
PORT=3000

# PostgreSQL VPS connection config
DB_HOST=your-vps-postgres-ip-or-localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_postgres_password
DB_NAME=boda_gulu
DB_SSL=false

# Path to the Firebase Service Account private key JSON file
# Obtained from your Firebase Console -> Project Settings -> Service accounts
# e.g., FIREBASE_SERVICE_ACCOUNT_PATH=/var/www/boda-gulu/firebase-key.json
FIREBASE_SERVICE_ACCOUNT_PATH=
